{
  "name": "domfw",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "build": "tsc && vite build",
    "dev": "vite",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "lint:fix": "eslint src --fix",
    "format": "prettier --check src",
    "format:fix": "prettier --write src"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.2.112",
    "@pixi/layout": "3.2.0",
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.3.2",
    "gsap": "^3.15.0",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@nnmbzr/assetpack-core": "1.7.1",
    "@pixi/devtools": "^2.0.1",
    "eslint": "9.17.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "4.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "@types/react",
        "yoga-layout"
      ]
    }
  }
}
